generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  OPERATOR
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model Project {
  id          String @id @default(cuid())
  projectName String
  ownerName   String
  mobileNo    String

  documents   Document[]
  inventory   Inventory[]
  feedLogs    FeedLog[]
  users       User[]
}

model Document {
  id                    String  @id @default(cuid())
  projectId             String
  subProject            String
  quantity              Int
  chequeNumber          String
  guarantorName         String
  deedFileUrl           String
  guarantorChequeFileUrl String
  nidFileUrl            String
  tradeLicenseFileUrl    String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Inventory {
  id            String   @id @default(cuid())
  projectId     String
  subProject    String
  fishQuantity  Int
  sizeMon       Decimal  @db.Decimal(18, 6)
  totalWeightKg Decimal  @db.Decimal(18, 3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model FeedLog {
  id              String   @id @default(cuid())
  projectId       String
  entryDate       DateTime
  openingBalance  Decimal  @db.Decimal(18, 3)
  additionAmount  Decimal  @db.Decimal(18, 3)
  dailyUse        Decimal  @db.Decimal(18, 3)
  closingBalance  Decimal  @db.Decimal(18, 3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([entryDate])
}