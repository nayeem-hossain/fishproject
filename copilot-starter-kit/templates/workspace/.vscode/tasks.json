{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Copilot Kit: Auto Sync",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/copilot-starter-kit/scripts/apply-kit.ps1",
        "-TargetWorkspace",
        "${workspaceFolder}",
        "-KitTier",
        "standard",
        "-Mode",
        "Auto"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    }
  ]
}
