# Database — Vercel Postgres (copy from Vercel dashboard → Storage → .env.local)
POSTGRES_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
POSTGRES_PRISMA_URL="postgresql://user:password@host:5432/dbname?sslmode=require&pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth — generate a secret: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob — copy from Vercel dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
