// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum Role {
  ADMIN
  OPERATOR
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(OPERATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id          String      @id @default(cuid())
  projectName String
  ownerName   String
  mobileNo    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  documents   Document[]
  inventories Inventory[]
  feedLogs    FeedLog[]
}

model Document {
  id                    String  @id @default(cuid())
  projectId             String
  project               Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject            String
  quantity              Int
  chequeNumber          String
  guarantorName         String
  deedFileUrl           String?
  guarantorChequeFileUrl String?
  nidFileUrl            String?
  tradeLicenseFileUrl   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Inventory {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject     String
  fishQuantity   Int
  sizeMon        Float
  totalWeightKg  Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FeedLog {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entryDate      DateTime
  openingBalance Float
  additionAmount Float
  dailyUse       Float
  closingBalance Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
